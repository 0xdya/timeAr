{
  "name": "@0xdya/artime",
  "version": "1.0.2",
  "description": "Arabic relative time library — مكتبة الوقت النسبي بالعربية",
  "main": "dist/artime.cjs.js",
  "module": "dist/artime.esm.js",
  "browser": "dist/artime.umd.js",
  "types": "dist/artime.d.ts",
  "exports": {
    ".": {
      "import": "./dist/artime.esm.js",
      "require": "./dist/artime.cjs.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c"
  },
  "keywords": [
    "js",
    "arabic",
    "time",
    "relative",
    "date",
    "تاريخ",
    "عربي"
  ],
  "author": "0xdya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xdya/ArTime"
  },
  "devDependencies": {
    "rollup": "^4.59.1"
  }
}
